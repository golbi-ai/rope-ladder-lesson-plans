{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rope-ladder public curriculum metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "name", "description", "tags", "attestation"],
  "properties": {
    "format": { "const": 1 },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "codebase": { "type": "string", "format": "uri", "maxLength": 500 },
    "description": { "type": "string", "minLength": 1, "maxLength": 600 },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,31}$" },
      "uniqueItems": true
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_source", "rights_to_publish"],
      "properties": {
        "public_source": { "const": true },
        "rights_to_publish": { "const": true }
      }
    }
  }
}
